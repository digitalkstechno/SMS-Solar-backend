ble .desc-col b { color: var(--ink); font-weight: 600; font-size: 13px; }@media(max-width:800px){.app{display:block}.editor{position:relative;height:auto}.workspace{padding:10px}.page{padding:30px 23px 60px;min-height:950px}.coverHero{padding:34px 25px}.coverInfo{padding:28px 25px}.footer{left:23px;right:23px}.kpis,.cards{grid-template-columns:repeat(2,1fr)}.meta{text-align:left}}@media print{body{background:#fff}.editor,.toolbar{display:none !important}.workspace{padding:0 !important}.book{width:100% !important}.page,.page.active{display:block !important;box-shadow:none !important;min-height:290mm !important;height:auto !important;margin:0 !important;padding:40px 40px !important;border:none !important;page-break-after:always !important;break-after:page !important;page-break-inside:avoid !important;break-inside:avoid !important}.page.cover,.page.cover.active{min-height:980px !important;padding:0 !important;page-break-after:always !important;break-after:page !important}.page.thanks,.page.thanks.active{min-height:980px !important;padding:80px 40px !important;page-break-before:always !important;break-before:page !important}.coverHero{padding:50px 40px !important}.coverInfo{padding:40px 40px !important}.footer{left:40px !important;right:40px !important;display:none !important}h1,h2,h3,.kicker{page-break-after:avoid !important;break-after:avoid !important}.panel,.offer,.cards,.kpis,.steps,.table,.quote,.signature,.twocol,.kpi,.card,.row,.bars{page-break-inside:avoid !important;break-inside:avoid !important}@page{size:A4;margin:0}}.page.accept-thanks,.page.accept-thanks.active{padding:0 !important;display:flex !important;flex-direction:column !important;min-height:980px !important;page-break-inside:avoid !important;break-inside:avoid !important}.accept-half{padding:40px;flex:1.45;position:relative}.thanks-half{background:linear-gradient(145deg,#4a1a33,#A63C71);color:#fff;padding:40px;flex:0.55;position:relative;display:flex;flex-direction:column;justify-content:center}}
</style></head><body><div class="app"><main class="workspace"><div id="injectedData" style="display:none;"><input id="size" value="<%= quotation.rows.find(r => r.title === 'Size (kW)')?.values[0] || 5 %>" />
